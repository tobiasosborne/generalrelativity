\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{gr-style}[2026/02/23 General Relativity lecture notes style]

% ── Options ───────────────────────────────────────────────────
% Pass [cmfonts] to use standard Computer Modern (no mtpro2/mathspec)
\newif\ifgr@cmfonts
\gr@cmfontsfalse
\DeclareOption{cmfonts}{\gr@cmfontstrue}
\ProcessOptions\relax

% ── Geometry ──────────────────────────────────────────────────
\RequirePackage{geometry}
\geometry{a4paper, margin=2.5cm}

% ── Colour palette (Birren industrial safety, base palette) ──
\RequirePackage{color}
\RequirePackage[table]{xcolor}

\definecolor{spacecadet}{HTML}{3D7A55}    % Safety green (dark anchor)
\definecolor{munsell}{HTML}{5B8C6F}       % Medium green (structure)
\definecolor{banana}{HTML}{E8B630}        % Solar yellow (caution/highlight)
\definecolor{cgblue}{HTML}{4A7FB5}        % Caution blue (information)
\definecolor{isabelline}{HTML}{A8D5BA}    % Seafoam (fatigue-free fill)
\definecolor{light-gray}{HTML}{D4C9A8}    % Beige (warm neutral)
% Additional Birren signal colours
\definecolor{birrenred}{HTML}{C4392F}     % Fire red (emergency)
\definecolor{birrenorange}{HTML}{D97A2B}  % Alert orange (hazard)
\definecolor{birrencologne}{HTML}{6B8E6B} % Cologne bridge green (muted)
\definecolor{birrengray}{HTML}{8C8C84}    % Medium gray (infrastructure)

% ── Graphics and figures ──────────────────────────────────────
\RequirePackage{graphicx}
\RequirePackage{wrapfig}

% ── Boxes (loaded early to avoid mathspec conflict) ──────────
\RequirePackage[many]{tcolorbox}
\RequirePackage[textsize=tiny]{todonotes}

% ── Math fonts ────────────────────────────────────────────────
\ifgr@cmfonts
  % ── Computer Modern fallback (portable, no proprietary fonts) ──
  \RequirePackage{amsmath}
  \RequirePackage{amsthm}
  \RequirePackage{mathtools}
  \RequirePackage{fontspec}
  \RequirePackage{amssymb}
  \RequirePackage{mathrsfs}
\else
  % ── Full font stack (Times LT Std + Whitney + mtpro2) ─────────
  % Load order: amsmath → mathtools → mtpro2 → mathspec (mathspec
  % requires amsmath to be fully loaded first)
  \RequirePackage{amsmath}
  \RequirePackage{amsthm}
  \RequirePackage{mathtools}
  \RequirePackage[mtphrb,mtpcal,mtpfrak]{mtpro2}
  \RequirePackage{mathspec}
  \RequirePackage{mathrsfs}
  \setmathrm{Times LT Std}
  \setmainfont[
    BoldFont      = Times LT Std Bold,
    ItalicFont    = Times LT Std Italic,
    BoldItalicFont= Times LT Std Bold Italic,
    Ligatures     = TeX
  ]{Times LT Std}
  \setsansfont[
    BoldFont   = Whitney-Semibold.otf,
    ItalicFont = Whitney-MediumItalic.otf,
    Ligatures  = TeX
  ]{Whitney-Medium.otf}
  \setboldmathrm[BoldFont={Times LT Std Bold}]{Times LT Std Bold}
\fi

% ── TikZ & pgfplots ──────────────────────────────────────────
\RequirePackage{tikz}
\usetikzlibrary{calc,arrows.meta,decorations.markings,patterns,
  positioning,shapes.geometric,backgrounds,matrix,fit}
\RequirePackage{pgfplots}
\pgfplotsset{compat=1.18}
\usepgfplotslibrary{patchplots,fillbetween}

% ── Lists ─────────────────────────────────────────────────────
\RequirePackage{enumerate}
\RequirePackage{booktabs}

% ── Hyperlinks ────────────────────────────────────────────────
\RequirePackage[colorlinks=true,linkcolor=munsell,citecolor=munsell,urlcolor=munsell]{hyperref}

% ── Section formatting ────────────────────────────────────────
\makeatletter
\def\@secnumfont{\bfseries}
\def\part{\@startsection{part}{0}%
  \z@{\linespacing\@plus\linespacing}{.5\linespacing}%
  {\normalfont\bfseries\raggedright}}
\def\specialsection{\@startsection{section}{1}%
  \z@{\linespacing\@plus\linespacing}{.5\linespacing}%
  {\color{munsell}\normalfont\centering}}
\def\section{\@startsection{section}{1}%
  \z@{.7\linespacing\@plus\linespacing}{.5\linespacing}%
  {\color{munsell}\normalfont\sf\bfseries\large\centering}}
\def\subsection{\@startsection{subsection}{2}%
  \z@{.5\linespacing\@plus.7\linespacing}{-.5em}%
  {\color{munsell}\normalfont\sf\bfseries}}
\def\subsubsection{\@startsection{subsubsection}{3}%
  \z@{.5\linespacing\@plus.7\linespacing}{-.5em}%
  {\color{munsell}\normalfont\sf\itshape}}
% ── Title formatting (sans, same colour as headings) ─────────
\def\@settitle{\begin{center}%
  \baselineskip14\p@\relax
    \bfseries\sffamily\color{munsell}%
  \uppercasenonmath\@title
  \@title
  \end{center}%
}
\makeatother

% ── Theorem environments ──────────────────────────────────────
\theoremstyle{plain}
\newtheorem{theorem}{Theorem}[section]
\newtheorem{lemma}[theorem]{Lemma}
\newtheorem{proposition}[theorem]{Proposition}
\newtheorem*{corollary}{Corollary}

\theoremstyle{definition}
\newtheorem{definition}{\color{munsell}Definition}[section]
\newtheorem{example}{\color{munsell}Example}[section]
\newtheorem{exercise}{\color{munsell}Exercise}[section]

\theoremstyle{remark}
\newtheorem*{remark}{Remark}
\newtheorem*{note}{Note}
\newtheorem*{notation}{Notation}

\newenvironment{solution}
  {\begin{proof}[\color{munsell}Solution]\color{spacecadet}}
  {\end{proof}}

% ── Highlighted boxes ─────────────────────────────────────────
% Key equation box (banana highlight)
\def\eqbox#1{\tcboxmath[colback=banana,arc=0cm,frame hidden,enhanced]{#1}}

% Two box types:
%   (1) Standard grey — grey background, no border, title inside
%   (2) Highlight yellow+blue — yellow background, blue border, title inside

% --- Standard grey box (no border) ---
\newtcolorbox{greybox}[1][]{%
  enhanced, breakable,
  colback=isabelline, frame hidden,
  arc=3pt,
  left=8pt, right=8pt, top=8pt, bottom=6pt,
  detach title, before upper={\textbf{\textsf{\color{black}#1}}\par\smallskip}}

% --- Highlight box (yellow background, blue border) ---
\newtcolorbox{highlightbox}[1][]{%
  enhanced, breakable,
  colback=isabelline, frame hidden,
  arc=3pt,
  left=8pt, right=8pt, top=8pt, bottom=6pt,
  detach title, before upper={\textbf{\textsf{\color{black}#1}}\par\smallskip}}

% Map semantic environments to the two box types
% keyresult → highlight (important results deserve emphasis)
\newtcolorbox{keyresult}[1][]{%
  enhanced, breakable,
  colback=isabelline, frame hidden,
  arc=3pt,
  left=8pt, right=8pt, top=8pt, bottom=6pt,
  detach title, before upper={\textbf{\textsf{\color{black}#1}}\par\smallskip}}
% intuition → grey
\newtcolorbox{intuition}[1][Physical intuition]{%
  enhanced, breakable,
  colback=isabelline, frame hidden,
  arc=3pt,
  left=8pt, right=8pt, top=8pt, bottom=6pt,
  detach title, before upper={\textbf{\textsf{\color{black}#1}}\par\smallskip}}
% historical → grey
\newtcolorbox{historical}[1][Historical note]{%
  enhanced, breakable,
  colback=isabelline, frame hidden,
  arc=3pt,
  left=8pt, right=8pt, top=8pt, bottom=6pt,
  detach title, before upper={\textbf{\textsf{\color{black}#1}}\par\smallskip}}
% algorithmbox → grey
\newtcolorbox{algorithmbox}[1][Algorithm]{%
  enhanced, breakable,
  colback=isabelline, frame hidden,
  arc=3pt,
  left=8pt, right=8pt, top=8pt, bottom=6pt,
  detach title, before upper={\textbf{\textsf{\color{black}#1}}\par\smallskip}}
% Figure placeholder
\def\figbox{\begin{center}\tcboxmath[colback=isabelline,frame hidden,enhanced,sharp corners]{\parbox[c][3cm][c]{10cm}{\ }}\end{center}}

\endinput
