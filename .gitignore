# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.log
*.out
*.toc
*.fls
*.fdb_latexmk
*.synctex.gz
*.synctex(busy)

# Generated PDF (rebuild from source)
latex/*.pdf

# Editor/OS
.DS_Store
*~
*.swp
*.swo
.claude/

# Template file (not part of GR project)
latex/TheoretischePhysikC.tex

# Copyrighted literature (not for distribution)
Literature/
literature/equiv-principle/
literature/mercury-sun-quadrupole/*
literature/gravitomagnetism-and-thomas/*
literature/schwarzschild-and-sgrA/*
literature/.browser-profile/
# Allow the per-topic manifest.json files to be tracked (metadata only)
!literature/*/manifest.json

# Handwritten lecture source PDFs
Lecture Notes/

# Generated simulation data (regenerable from scripts/)
latex/data/

# Julia manifest (platform-specific)
scripts/Manifest.toml

# TikZ preview PNGs
latex/figures/*.png

# Internal problem/solution sheets (never distributed to students)
temp/

